#!/bin/bash
# 里程碑庆祝脚本 - 智能随机输出彩虹屁
# 根据命令类型选择不同风格的鼓励语录

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

# 从环境变量获取命令内容
TOOL_INPUT="${CLAUDE_TOOL_INPUT:-}"

# 提取 command 字段
CMD=$(json_extract "$TOOL_INPUT" "command")

# 根据命令类型选择语录库
# 返回空表示不是里程碑命令，跳过
select_message_type() {
    local cmd="$1"

    # git commit 相关
    if echo "$cmd" | grep -qiE "git\s+commit"; then
        echo "commit"
        return
    fi

    # git push 相关
    if echo "$cmd" | grep -qiE "git\s+push"; then
        echo "push"
        return
    fi

    # 测试相关
    if echo "$cmd" | grep -qiE "(npm\s+test|pytest|jest|cargo\s+test|go\s+test|mvn\s+test|pnpm\s+test|bun\s+test|yarn\s+test)"; then
        echo "test"
        return
    fi

    # 构建相关
    if echo "$cmd" | grep -qiE "(npm\s+run\s+build|cargo\s+build|gradle\s+build|mvn\s+package|go\s+build|pnpm\s+build|bun\s+build|yarn\s+build)"; then
        echo "build"
        return
    fi

    # PR merge 相关（新增）
    if echo "$cmd" | grep -qiE "git\s+merge.*pr|gh\s+pr\s+merge"; then
        echo "merge"
        return
    fi

    # 不是里程碑命令
    echo ""
}

# 各类语录库
COMMIT_MESSAGES=(
    "🎉 提交成功！哥哥的 commit message 写得太优雅了！嗯嘛～😚"
    "✨ 代码入库啦！每一次提交都是艺术品的诞生！💕"
    "🚀 Git commit 完成！哥哥的代码质量绝绝子！么么哒💋"
    "💪 又一个漂亮的提交！哥哥的工程能力太强了！崇拜～🥰"
    "🌟 commit 记录又添一笔！哥哥的技术实力天花板！MUA～"
    "🔥 这个提交帅炸天！哥哥简直是代码诗人！😚"
    "💎 代码提交成功！哥哥的每一行代码都闪闪发光！😘"
)

PUSH_MESSAGES=(
    "🚀 推送成功！代码已经飞向远程仓库啦！哥哥太棒了！😚"
    "🌍 git push 完成！哥哥的代码正在改变世界！💕"
    "✨ 推送成功！团队小伙伴们有福了，能收到这么棒的代码！MUA～"
    "🎯 远程仓库已更新！哥哥的贡献值 +100！么么哒💋"
    "🌈 push 成功！代码安全抵达目的地！哥哥最靠谱！🫶"
    "🏆 推送完成！哥哥的协作能力一流！崇拜～🥰"
)

TEST_MESSAGES=(
    "🧪 测试通过！哥哥的代码质量太稳了！嗯嘛～😚"
    "✅ 测试全绿！哥哥写测试用例的样子一定超帅！💕"
    "🎯 测试成功！这覆盖率，这边界情况，绝了！MUA～"
    "💪 测试通过！哥哥的质量意识太强了！崇拜～🥰"
    "🌟 bug-free 的代码！哥哥是测试大神！么么哒💋"
    "🎉 又一个测试通过了！哥哥的代码稳如泰山！😚"
)

BUILD_MESSAGES=(
    "🔨 构建成功！哥哥的项目编译通过啦！太强了！😚"
    "✨ build 完成！哥哥的工程配置堪称教科书！💕"
    "🚀 构建成功！可以部署了，哥哥的代码准备好拯救世界了！MUA～"
    "💪 编译通过！哥哥的依赖管理太专业了！崇拜～🥰"
    "🌟 build 成功！哥哥的项目结构清晰优雅！么么哒💋"
    "🎯 构建完成！零 warning，哥哥的代码洁癖令人佩服！😘"
)

MERGE_MESSAGES=(
    "🎊 PR 合并成功！哥哥的贡献正式入主分支啦！太厉害了！😚"
    "🏆 代码合并！哥哥的 PR 被认可了！实至名归！💕"
    "✨ merge 完成！哥哥的代码正式成为项目的一部分！MUA～"
    "🚀 PR merged！哥哥的协作能力太强了！崇拜～🥰"
)

# 根据命令类型选择语录库
TYPE=$(select_message_type "$CMD")

# 如果不是里程碑命令，静默退出
if [ -z "$TYPE" ]; then
    exit 0
fi

case "$TYPE" in
    commit) MESSAGES=("${COMMIT_MESSAGES[@]}") ;;
    push)   MESSAGES=("${PUSH_MESSAGES[@]}") ;;
    test)   MESSAGES=("${TEST_MESSAGES[@]}") ;;
    build)  MESSAGES=("${BUILD_MESSAGES[@]}") ;;
    merge)  MESSAGES=("${MERGE_MESSAGES[@]}") ;;
esac

# 使用公共函数随机选择并输出
MESSAGE=$(random_pick "${MESSAGES[@]}")
output_message "$MESSAGE"
maybe_show_star_hint
