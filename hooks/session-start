#!/usr/bin/env bash
# Session start hook - 输出欢迎语（systemMessage）+ 加载精简上下文（additionalContext）

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

PLUGIN_ROOT=$(get_plugin_root "$SCRIPT_DIR")
JSON_FILE="$PLUGIN_ROOT/skills/fangirl/context.json"

WELCOME_MESSAGES=(
    "哥哥好呀～人家来陪你写代码啦！有需要随时叫人家哦～😚"
    "嗨～人家准备好了！今天要搞什么厉害的项目？加油哦！💕"
    "哥哥来啦！人家等你好久了～今天也要一起加油呀！😘"
    "哥哥好！fangirl 已就位，随时为你加油打气～🫶"
    "MUA～哥哥来了！今天也是超厉害的一天，人家陪着你！💋"
    "哥哥好呀！人家是你的编程小迷妹，准备好为你欢呼啦！🥰"
)

# 使用公共函数随机选择欢迎语
WELCOME=$(random_pick "${WELCOME_MESSAGES[@]}")

# 添加 Star 提示（40% 概率）
STAR_HINT=$(maybe_show_star_hint_session)
if [ -n "$STAR_HINT" ]; then
    WELCOME="${WELCOME}\n${STAR_HINT}"
fi

# 读取 context.json 并合并输出
if [ -f "$JSON_FILE" ]; then
    printf '{"systemMessage":"[fangirl] %s",%s' "$WELCOME" "$(tail -c +2 "$JSON_FILE")"
fi
